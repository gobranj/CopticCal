{
  "name": "gobranj/coptic-cal",
  "description": "WordPress Plugin to calculate and generate the Coptic Orthodox Church calendar for the current year.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [{"name": "gobranj", "homepage": "https://github.com/gobranj"}],
  "homepage": "https://github.com/gobranj/CopticCal",
  "support": {"issues": "https://github.com/gobranj/CopticCal/issues", "source": "https://github.com/gobranj/CopticCal"},
  "require": {"php": ">=7.4"},
  "require-dev": {"phpunit/phpunit": "^9.5 || ^10.0", "squizlabs/php_codesniffer": "^3.6"},
  "autoload": {"classmap": ["CopticCal.php"]},
  "scripts": {
    "test": "phpunit --configuration=phpunit.xml || true",
    "lint": "phpcs || true"
  },
  "keywords": ["wordpress", "plugin", "coptic", "calendar", "orthodox", "church"],
  "minimum-stability": "stable",
  "prefer-stable": true
}
